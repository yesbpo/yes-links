{
  "name": "yes-links-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal host app demonstrating @yes/links-ui SDK integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@yes/links-ui": "file:../yes-links-ui",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
